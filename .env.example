# GigShield AI - Environment Variables Template
# Copy this file to .env and fill in your API keys
# NEVER commit .env to git!

# OpenWeatherMap API Key (https://openweathermap.org/api)
EXPO_PUBLIC_OPENWEATHER_API_KEY=your_openweathermap_api_key_here

# Google OAuth Web Client ID (https://console.cloud.google.com/apis/credentials)
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=your_google_web_client_id_here

# Google OAuth Android Client ID
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=your_google_android_client_id_here
